# Entorno (development, production, test)
NODE_ENV=development

# Puerto en el que escucha la aplicación
PORT=3000

# Nivel de logging (error, warn, info, debug)
LOG_LEVEL=info

# Clave API (opcional)
API_KEY=

# URL de la base de datos (opcional)
DATABASE_URL=

# Secreto JWT (opcional)
JWT_SECRET=
